{
  "uid": "spidey-agent-ops",
  "title": "Spidey — Agent Operations",
  "tags": ["spidey", "agents"],
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Tool invocations/sec by tool",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool) (rate(spidey_tool_invocations_total[5m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Tool outcomes (ok / error / denied)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(spidey_tool_invocations_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Policy denials (last 1h)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spidey_tool_invocations_total{outcome=\"denied\"}[1h]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Write-effect tool calls/sec (side_effect=write)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool) (rate(spidey_tool_invocations_total{side_effect=\"write\"}[5m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    }
  ]
}
