{
  "uid": "spidey-cost",
  "title": "Spidey — Cost",
  "tags": ["spidey", "cost"],
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM spend $/hour by model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (rate(spidey_llm_cost_usd_total[1h])) * 3600",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Spend last 24h (USD)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(spidey_llm_cost_usd_total[24h]))" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Spend by role",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (role) (rate(spidey_llm_cost_usd_total[1h])) * 3600",
          "legendFormat": "{{role}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tokens/sec by direction",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (direction) (rate(spidey_llm_tokens_total[5m]))",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Spend by provider",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(spidey_llm_cost_usd_total[1h])) * 3600",
          "legendFormat": "{{provider}}"
        }
      ]
    }
  ]
}
