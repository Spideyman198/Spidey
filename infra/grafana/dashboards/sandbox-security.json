{
  "uid": "spidey-sandbox-sec",
  "title": "Spidey — Sandbox & Security",
  "tags": ["spidey", "security"],
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Sandboxed executions/sec (terminal + tester)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool) (rate(spidey_tool_invocations_total{tool=~\".*(terminal|tester).*\"}[5m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Policy denials (last 6h)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spidey_tool_invocations_total{outcome=\"denied\"}[6h]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "MCP definition-drift alarms (last 6h)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(spidey_mcp_drift_alarms_total[6h]))" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tool errors/sec by tool",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool) (rate(spidey_tool_invocations_total{outcome=\"error\"}[5m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    }
  ]
}
