# ──────────────────────────────────────────────────────────────────────────────
# Spidey environment configuration — copy to .env and fill in real values.
# Every variable the application reads is documented here. No real secrets in
# this file, ever. Settings are validated at startup; the app fails fast if a
# required variable is missing (see backend/src/spidey/platform/config.py).
#
# Host URLs use 127.0.0.1 rather than localhost deliberately: on Windows,
# localhost can resolve to ::1, where Docker Desktop's port proxy accepts the
# TCP handshake but routes nowhere — connections then hang until timeout.
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
# Environment name: dev | test | staging | prod. Controls log rendering
# (pretty console in dev, JSON elsewhere) and error detail exposure.
SPIDEY_ENVIRONMENT=dev

# Log level: DEBUG | INFO | WARNING | ERROR
SPIDEY_LOG_LEVEL=INFO

# ── Backing services (required) ───────────────────────────────────────────────
# PostgreSQL DSN (asyncpg driver). Compose default shown; change for prod.
SPIDEY_DATABASE_URL=postgresql+asyncpg://spidey:spidey-dev-password@127.0.0.1:5432/spidey

# Redis URL. DB 0 = Celery broker/results, DB 1 = app (rate limits, streams, cache).
SPIDEY_REDIS_URL=redis://127.0.0.1:6379/0

# Qdrant HTTP endpoint (client dependency arrives in M4; M0 health-probes it).
SPIDEY_QDRANT_URL=http://127.0.0.1:6333

# ── Observability (optional — telemetry degrades to no-op when unset) ─────────
# OTLP HTTP/protobuf endpoint of the OpenTelemetry Collector.
SPIDEY_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# Service name reported in traces/metrics.
SPIDEY_OTEL_SERVICE_NAME=spidey

# ── API ───────────────────────────────────────────────────────────────────────
# Comma-separated CORS allow-list. Keep tight; "*" is rejected by validation.
SPIDEY_CORS_ORIGINS=http://localhost:5173

# ── Compose-only variables (read by deploy/compose/docker-compose.yml) ────────
# Credentials for the dev Postgres container. Rotate for anything non-local.
POSTGRES_USER=spidey
POSTGRES_PASSWORD=spidey-dev-password
POSTGRES_DB=spidey
# Grafana admin bootstrap credentials (dev only).
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-locally
