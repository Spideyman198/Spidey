{
  "components": {
    "schemas": {
      "ComponentHealth": {
        "properties": {
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "latency_ms": {
            "title": "Latency Ms",
            "type": "number"
          },
          "status": {
            "enum": [
              "ok",
              "down"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "latency_ms"
        ],
        "title": "ComponentHealth",
        "type": "object"
      },
      "LivenessReport": {
        "properties": {
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "LivenessReport",
        "type": "object"
      },
      "ReadinessReport": {
        "properties": {
          "components": {
            "additionalProperties": {
              "$ref": "#/components/schemas/ComponentHealth"
            },
            "title": "Components",
            "type": "object"
          },
          "status": {
            "enum": [
              "ok",
              "degraded",
              "unavailable"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "components"
        ],
        "title": "ReadinessReport",
        "type": "object"
      }
    }
  },
  "info": {
    "summary": "Autonomous coding agent platform",
    "title": "Spidey API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/health/live": {
      "get": {
        "description": "Process is up and serving. No dependency checks \u2014 restart decisions only.",
        "operationId": "live_api_v1_health_live_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LivenessReport"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "health"
        ]
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "description": "Dependency-checked readiness with per-component detail.",
        "operationId": "ready_api_v1_health_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessReport"
                }
              }
            },
            "description": "Successful Response"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessReport"
                }
              }
            },
            "description": "A critical dependency is down"
          }
        },
        "summary": "Readiness probe",
        "tags": [
          "health"
        ]
      }
    }
  }
}
